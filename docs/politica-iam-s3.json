{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListarSoloBucketArchivacloudPrefijoUploads",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::archivacloud-p07",
      "Condition": {
        "StringLike": {
          "s3:prefix": "uploads/*"
        }
      }
    },
    {
      "Sid": "OperarObjetosSoloBajoUploads",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::archivacloud-p07/uploads/*"
    }
  ]
}
